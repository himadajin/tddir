#!/bin/bash
set -eu

usage() {
    echo "Usage: tddir [-p <prefix>] [-c zsh] [-h]" >&2
    echo "  -p <prefix>  Use <prefix> as the base directory (default: ~/works)" >&2
    echo "  -c <shell>   Output completion script (supported: zsh)" >&2
    echo "  -h           Show this help" >&2
}

completion_zsh() {
    cat <<'EOF'
_tddir() {
    _arguments \
        '-p[Use custom base directory]:prefix:_files -/' \
        '-c[Output completion script]:shell:(zsh)' \
        '-h[Show this help]'
}
compdef _tddir tddir
EOF
}

PREFIX="${HOME}/works"

while getopts "p:c:h" opt; do
    case "$opt" in
        p) PREFIX="$OPTARG" ;;
        c) case "$OPTARG" in
               zsh) completion_zsh; exit 0 ;;
               *)   echo "Unsupported shell: '$OPTARG'. Supported: zsh" >&2; exit 1 ;;
           esac ;;
        h) usage; exit 0 ;;
        *) usage; exit 1 ;;
    esac
done

DIR="${PREFIX}/$(date "+%Y-%m-%d")"
mkdir -p "$DIR"
echo "$DIR"
